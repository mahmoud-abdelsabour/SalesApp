@model WebApplication2.Models.ViewModels.InvoiceDetailsViewModel
@{
    ViewBag.Title = WebApplication2.Resources.Labels.InvoiceNumber + " " + Model.InvoiceNumber;
}

<div class="d-flex justify-content-between mb-3 no-print">
    <a href="/Invoices/Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left mr-1"></i>@WebApplication2.Resources.Labels.Cancel
    </a>
    <button onclick="window.print()" class="btn btn-primary">
        <i class="fas fa-print mr-1"></i>Print
    </button>
</div>

<div class="card" id="invoicePrintArea">
    <div class="card-body">
        <!-- Invoice Header -->
        <div class="row mb-4">
            <div class="col-md-6">
                <h4 class="text-primary font-weight-bold">@WebApplication2.Resources.Labels.AppName</h4>
                <p class="text-muted mb-0">@WebApplication2.Resources.Labels.CreateInvoice</p>
            </div>
            <div class="col-md-6 text-right">
                <h5 class="font-weight-bold">@WebApplication2.Resources.Labels.InvoiceNumber: @Model.InvoiceNumber</h5>
                <p class="mb-0">@WebApplication2.Resources.Labels.InvoiceDate: @Model.InvoiceDate.ToString("yyyy-MM-dd HH:mm")</p>
                <p class="mb-0">
                    @if (Model.Status == "Confirmed")
                    {
                        <span class="badge badge-success">@Model.Status</span>
                    }
                    else if (Model.Status == "Cancelled")
                    {
                        <span class="badge badge-danger">@Model.Status</span>
                    }
                    else
                    {
                        <span class="badge badge-warning">@Model.Status</span>
                    }
                </p>
            </div>
        </div>

        <hr />

        <!-- Customer Info -->
        <div class="row mb-4">
            <div class="col-md-6">
                <h6 class="font-weight-bold">@WebApplication2.Resources.Labels.InvoiceCustomer</h6>
                <p class="mb-0">@Model.CustomerName</p>
                <p class="mb-0">@Model.CustomerPhone</p>
                <p class="mb-0">@Model.CustomerEmail</p>
            </div>
            <div class="col-md-6 text-right">
                <h6 class="font-weight-bold">Created By</h6>
                <p class="mb-0">@Model.CreatedBy</p>
            </div>
        </div>

        <!-- Items Table -->
        <div class="table-responsive">
            <table class="table table-bordered">
                <thead class="thead-light">
                    <tr>
                        <th>#</th>
                        <th>@WebApplication2.Resources.Labels.InvoiceProducts</th>
                        <th class="text-right">@WebApplication2.Resources.Labels.InvoiceUnitPrice</th>
                        <th class="text-right">@WebApplication2.Resources.Labels.InvoiceQty</th>
                        <th class="text-right">@WebApplication2.Resources.Labels.InvoiceDiscount</th>
                        <th class="text-right">@WebApplication2.Resources.Labels.InvoiceLineTotal</th>
                    </tr>
                </thead>
                <tbody>
                    @{int i = 1;}
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@i</td>
                            <td>@item.ProductName</td>
                            <td class="text-right">@item.UnitPrice.ToString("N2")</td>
                            <td class="text-right">@item.Quantity</td>
                            <td class="text-right">@item.DiscountPct.ToString("N2")%</td>
                            <td class="text-right">@item.LineTotal.ToString("N2")</td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>

        <!-- Totals -->
        <div class="row justify-content-end">
            <div class="col-md-4">
                <table class="table table-sm">
                    <tr>
                        <td><strong>@WebApplication2.Resources.Labels.InvoiceSubTotal</strong></td>
                        <td class="text-right">@Model.SubTotal.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td><strong>@WebApplication2.Resources.Labels.InvoiceDiscountAmt (@Model.InvoiceDiscountPct%)</strong></td>
                        <td class="text-right">@Model.InvoiceDiscountAmt.ToString("N2")</td>
                    </tr>
                    <tr class="table-primary">
                        <td><strong>@WebApplication2.Resources.Labels.InvoiceTotal</strong></td>
                        <td class="text-right"><strong>@Model.TotalAmount.ToString("N2")</strong></td>
                    </tr>
                </table>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="mt-3">
                <h6 class="font-weight-bold">@WebApplication2.Resources.Labels.InvoiceNotes</h6>
                <p>@Model.Notes</p>
            </div>
        }
    </div>
</div>

<style>
    @@media print {
        .no-print {
            display: none !important;
        }

        .navbar {
            display: none !important;
        }

        .main-content {
            padding: 0 !important;
        }

        .card {
            box-shadow: none !important;
            border: none !important;
        }

        body {
            background: white !important;
        }
    }
</style>