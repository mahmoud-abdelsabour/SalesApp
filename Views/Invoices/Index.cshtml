@model IEnumerable<WebApplication2.Models.ViewModels.InvoiceListViewModel>
@{
    ViewBag.Title = WebApplication2.Resources.Labels.Invoices;
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-list mr-2"></i>@WebApplication2.Resources.Labels.Invoices</span>
        <a href="/Invoices/Create" class="btn btn-sm btn-light">
            <i class="fas fa-plus mr-1"></i>@WebApplication2.Resources.Labels.CreateInvoice
        </a>
    </div>
    <div class="card-body">

        <!-- Filter Row -->
        @using (Html.BeginForm("Index", "Invoices", FormMethod.Get))
        {
            <div class="row mb-3">
                <div class="col-md-2">
                    <label class="small">@WebApplication2.Resources.Labels.FilterDateFrom</label>
                    <input type="date" name="dateFrom" value="@ViewBag.DateFrom" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label class="small">@WebApplication2.Resources.Labels.FilterDateTo</label>
                    <input type="date" name="dateTo" value="@ViewBag.DateTo" class="form-control form-control-sm" />
                </div>
                <div class="col-md-3">
                    <label class="small">@WebApplication2.Resources.Labels.InvoiceCustomer</label>
                    <select name="customerId" id="customerFilter" class="form-control form-control-sm" style="width:100%">
                        <option value="">@WebApplication2.Resources.Labels.FilterAll</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="small">@WebApplication2.Resources.Labels.FilterStatus</label>
                    <select name="status" class="form-control form-control-sm">
                        <option value="">@WebApplication2.Resources.Labels.FilterAll</option>
                        <option value="Confirmed" @(ViewBag.Status == "Confirmed" ? "selected" : "")>@WebApplication2.Resources.Labels.FilterConfirmed</option>
                        <option value="Cancelled" @(ViewBag.Status == "Cancelled" ? "selected" : "")>@WebApplication2.Resources.Labels.FilterCancelled</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary btn-sm mr-2">
                        <i class="fas fa-search mr-1"></i>@WebApplication2.Resources.Labels.Filter
                    </button>
                    <a href="/Invoices/Index" class="btn btn-secondary btn-sm">
                        <i class="fas fa-times mr-1"></i>@WebApplication2.Resources.Labels.ClearFilter
                    </a>
                </div>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>@WebApplication2.Resources.Labels.InvoiceNumber</th>
                        <th>@WebApplication2.Resources.Labels.InvoiceCustomer</th>
                        <th>@WebApplication2.Resources.Labels.InvoiceDate</th>
                        <th>@WebApplication2.Resources.Labels.InvoiceTotal</th>
                        <th>@WebApplication2.Resources.Labels.InvoiceStatus</th>
                        <th>@WebApplication2.Resources.Labels.Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">
                                @WebApplication2.Resources.Labels.NoData
                            </td>
                        </tr>
                    }
                    else
                    {
                        int i = 1;
                        foreach (var item in Model)
                        {
                            <tr id="row-@item.Id">
                                <td>@i</td>
                                <td>
                                    <a href="/Invoices/Details/@item.Id">@item.InvoiceNumber</a>
                                </td>
                                <td>@item.CustomerName</td>
                                <td>@item.InvoiceDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@item.TotalAmount.ToString("N2")</td>
                                <td>
                                    @if (item.Status == "Confirmed")
                                    {
                                        <span class="badge badge-success">@item.Status</span>
                                    }
                                    else if (item.Status == "Cancelled")
                                    {
                                        <span class="badge badge-danger">@item.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-warning">@item.Status</span>
                                    }
                                </td>
                                <td>
                                    <a href="/Invoices/Details/@item.Id" class="btn btn-sm btn-primary">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (item.Status != "Cancelled")
                                    {
                                        <button class="btn btn-sm btn-danger"
                                                onclick="confirmCancel(@item.Id, '@item.InvoiceNumber')">
                                            <i class="fas fa-ban"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                            i++;
                        }
                    }
                </tbody>
            </table>
        </div>
        @Html.Partial("_Pagination")
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        $(document).ready(function () {
            // Initialize customer filter Select2 with AJAX
            $('#customerFilter').select2({
                placeholder: '@WebApplication2.Resources.Labels.FilterAll',
                allowClear: true,
                ajax: {
                    url: '/Customers/Search',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) { return { term: params.term || '' }; },
                    processResults: function (data) { return { results: data }; }
                }
            });

            // Pre-select customer if filter is active
            var selectedCustomerId = '@ViewBag.CustomerId';
            if (selectedCustomerId) {
                $.get('/Customers/Search?term=', function (data) {
                    $.each(data, function (i, customer) {
                        if (customer.id == selectedCustomerId) {
                            var option = new Option(customer.text, customer.id, true, true);
                            $('#customerFilter').append(option).trigger('change');
                        }
                    });
                });
            }
        });

        function confirmCancel(id, number) {
            Swal.fire({
                title: 'Cancel Invoice?',
                text: 'Invoice ' + number + ' will be cancelled.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#1F3864',
                confirmButtonText: 'Yes, Cancel It',
                cancelButtonText: '@WebApplication2.Resources.Labels.Cancel'
            }).then(function (result) {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Invoices/Cancel/' + id,
                        type: 'POST',
                        data: {
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    title: response.message,
                                    icon: 'success',
                                    timer: 1500,
                                    showConfirmButton: false
                                }).then(function () { location.reload(); });
                            } else {
                                Swal.fire({ title: response.message, icon: 'error' });
                            }
                        }
                    });
                }
            });
        }
    </script>
}