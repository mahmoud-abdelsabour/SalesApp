@model WebApplication2.Models.ViewModels.ResetPasswordViewModel
@{
    ViewBag.Title = WebApplication2.Resources.Labels.ResetPassword;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-key mr-2"></i>@WebApplication2.Resources.Labels.ResetPassword — @Model.Username
            </div>
            <div class="card-body">
                @using (Html.BeginForm("ResetPassword", "Users", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.Id)
                    @Html.HiddenFor(m => m.Username)

                    if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @Html.ValidationSummary(false)
                        </div>
                    }

                    <div class="form-group">
                        <label>@WebApplication2.Resources.Labels.NewPassword <span class="text-danger">*</span></label>
                        @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger small" })
                        <small class="text-muted">Minimum 6 characters</small>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a href="/Users/Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left mr-1"></i>@WebApplication2.Resources.Labels.Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save mr-1"></i>@WebApplication2.Resources.Labels.Save
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>