@model WebApplication2.Models.ViewModels.LoginViewModel
@{
    Layout = null;
    var isArabic = WebApplication2.Helpers.LanguageHelper.IsArabic();
    var dir = isArabic ? "rtl" : "ltr";
    var lang = isArabic ? "ar" : "en";
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@WebApplication2.Resources.Labels.Login - @WebApplication2.Resources.Labels.AppName</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: linear-gradient(135deg, #0D1B2A 0%, #1B3A5C 50%, #1B6CA8 100%);
        }

        .login-wrapper {
            width: 100%;
            max-width: 420px;
            padding: 20px;
        }

        .login-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            overflow: hidden;
        }

        .login-header {
            background: linear-gradient(135deg, #0D1B2A 0%, #1B6CA8 100%);
            padding: 32px 36px 28px;
            text-align: center;
        }

            .login-header .logo-icon {
                width: 56px;
                height: 56px;
                background: rgba(255,255,255,0.15);
                border-radius: 14px;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 14px;
                font-size: 1.6rem;
                color: #fff;
            }

            .login-header h1 {
                color: #fff;
                font-size: 1.4rem;
                font-weight: 700;
                margin: 0 0 4px;
                letter-spacing: 0.3px;
            }

            .login-header p {
                color: rgba(255,255,255,0.6);
                font-size: 0.85rem;
                margin: 0;
            }

        .login-body {
            padding: 32px 36px;
        }

        .form-group {
            margin-bottom: 20px;
        }

            .form-group label {
                font-size: 0.85rem;
                font-weight: 600;
                color: #374151;
                margin-bottom: 6px;
                display: block;
            }

        .input-wrapper {
            position: relative;
        }

            .input-wrapper i {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: #9CA3AF;
                font-size: 0.9rem;
            }

        [dir="rtl"] .input-wrapper i {
            left: auto;
            right: 12px;
        }

        .input-wrapper input {
            width: 100%;
            padding: 10px 12px 10px 36px;
            border: 1.5px solid #E5E7EB;
            border-radius: 10px;
            font-size: 0.9rem;
            color: #1A202C;
            transition: all 0.2s;
            outline: none;
        }

        [dir="rtl"] .input-wrapper input {
            padding: 10px 36px 10px 12px;
        }

        .input-wrapper input:focus {
            border-color: #1B6CA8;
            box-shadow: 0 0 0 3px rgba(27,108,168,0.12);
        }

        .btn-login {
            width: 100%;
            padding: 11px;
            background: linear-gradient(135deg, #0D1B2A 0%, #1B6CA8 100%);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            letter-spacing: 0.3px;
        }

            .btn-login:hover {
                opacity: 0.92;
                transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(27,108,168,0.35);
            }

        .alert-danger {
            background: #FEF2F2;
            border: none;
            border-radius: 10px;
            color: #991B1B;
            font-size: 0.875rem;
            padding: 10px 14px;
            margin-bottom: 20px;
        }

        .lang-switch {
            text-align: center;
            margin-top: 20px;
        }

            .lang-switch a {
                color: rgba(255,255,255,0.7);
                font-size: 0.85rem;
                text-decoration: none;
                transition: color 0.2s;
            }

                .lang-switch a:hover {
                    color: #fff;
                }

        .text-danger {
            color: #DC2626;
            font-size: 0.8rem;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">
            <div class="login-header">
                <div class="logo-icon">
                    <i class="fas fa-chart-line"></i>
                </div>
                <h1>@WebApplication2.Resources.Labels.AppName</h1>
                <p>@WebApplication2.Resources.Labels.Login</p>
            </div>
            <div class="login-body">
                @using (Html.BeginForm("Login", "Auth", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert-danger">
                            <i class="fas fa-exclamation-circle mr-1"></i>
                            @Html.ValidationSummary(true)
                        </div>
                    }

                    <div class="form-group">
                        <label>@WebApplication2.Resources.Labels.Username</label>
                        <div class="input-wrapper">
                            <i class="fas fa-user"></i>
                            @Html.TextBoxFor(m => m.Username, new { placeholder = WebApplication2.Resources.Labels.Username })
                        </div>
                        @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label>@WebApplication2.Resources.Labels.Password</label>
                        <div class="input-wrapper">
                            <i class="fas fa-lock"></i>
                            @Html.PasswordFor(m => m.Password, new { placeholder = WebApplication2.Resources.Labels.Password })
                        </div>
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                    </div>

                    <button type="submit" class="btn-login">
                        <i class="fas fa-sign-in-alt mr-2"></i>@WebApplication2.Resources.Labels.Login
                    </button>
                }
            </div>
        </div>

        <div class="lang-switch">
            @if (isArabic)
            {
                <a href="/Auth/SetLanguage?lang=en">
                    <i class="fas fa-globe mr-1"></i>English
                </a>
            }
            else
            {
                <a href="/Auth/SetLanguage?lang=ar">
                    <i class="fas fa-globe mr-1"></i>العربية
                </a>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>