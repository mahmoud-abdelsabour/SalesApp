@model IEnumerable<WebApplication2.Models.ViewModels.CustomerViewModel>
@{
    ViewBag.Title = WebApplication2.Resources.Labels.Customers;
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-users mr-2"></i>@WebApplication2.Resources.Labels.Customers</span>
        <a href="/Customers/Create" class="btn btn-sm btn-light">
            <i class="fas fa-plus mr-1"></i>@WebApplication2.Resources.Labels.AddCustomer
        </a>
    </div>
    <div class="card-body">
        <!-- Search -->
        <div class="row mb-3">
            <div class="col-md-4">
                @using (Html.BeginForm("Index", "Customers", FormMethod.Get))
                {
                    <div class="input-group">
                        <input type="text" name="search" value="@ViewBag.Search"
                               class="form-control"
                               placeholder="@WebApplication2.Resources.Labels.Search..." />
                        <div class="input-group-append">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-search"></i>
                            </button>
                            <a href="/Customers/Index" class="btn btn-secondary">
                                <i class="fas fa-times"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>@WebApplication2.Resources.Labels.CustomerFullName</th>
                        <th>@WebApplication2.Resources.Labels.CustomerPhone</th>
                        <th>@WebApplication2.Resources.Labels.CustomerEmail</th>
                        <th>@WebApplication2.Resources.Labels.CustomerAddress</th>
                        <th>@WebApplication2.Resources.Labels.Invoices2</th>
                        <th>@WebApplication2.Resources.Labels.Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">
                                @WebApplication2.Resources.Labels.NoData
                            </td>
                        </tr>
                    }
                    else
                    {
                        int i = 1;
                        foreach (var item in Model)
                        {
                            <tr id="row-@item.Id">
                                <td>@i</td>
                                <td>@item.FullName</td>
                                <td>@item.Phone</td>
                                <td>@item.Email</td>
                                <td>@item.Address</td>
                                <td>
                                    <span class="badge badge-info">@item.InvoiceCount</span>
                                </td>
                                <td>
                                    <a href="/Customers/Edit/@item.Id" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button class="btn btn-sm btn-danger"
                                            onclick="confirmDelete(@item.Id, '@item.FullName')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                </tbody>
            </table>
        </div>
        @Html.Partial("_Pagination")
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        function confirmDelete(id, name) {
            Swal.fire({
                title: '@WebApplication2.Resources.Labels.ConfirmDelete',
                text: name,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#1F3864',
                confirmButtonText: '@WebApplication2.Resources.Labels.Yes',
                cancelButtonText: '@WebApplication2.Resources.Labels.Cancel'
            }).then(function (result) {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Customers/Delete/' + id,
                        type: 'POST',
                        data: {
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (response) {
                            if (response.success) {
                                $('#row-' + id).fadeOut(400, function () { $(this).remove(); });
                                Swal.fire({
                                    title: response.message,
                                    icon: 'success',
                                    timer: 1500,
                                    showConfirmButton: false
                                });
                            } else {
                                Swal.fire({
                                    title: response.message,
                                    icon: 'error'
                                });
                            }
                        }
                    });
                }
            });
        }
    </script>
}