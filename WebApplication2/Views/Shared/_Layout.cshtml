<!DOCTYPE html>
<html lang="@(WebApplication2.Helpers.LanguageHelper.IsArabic() ? "ar" : "en")"
      dir="@(WebApplication2.Helpers.LanguageHelper.IsArabic() ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - @WebApplication2.Resources.Labels.AppName</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.7.3/sweetalert2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        :root {
            --sidebar-width: 240px;
            --sidebar-collapsed-width: 60px;
            --navbar-height: 56px;
            --primary: #0D1B2A;
            --primary-hover: #1B6CA8;
            --accent: #00B4D8;
            --success: #2D9B6F;
            --warning: #F4A261;
            --danger: #E63946;
            --bg: #F0F4F8;
            --card-bg: #FFFFFF;
            --text-primary: #1A202C;
            --text-muted: #6B7280;
            --border: #E2E8F0;
        }

        body {
            background: var(--bg);
            color: var(--text-primary);
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            font-size: 15px;
            overflow-x: hidden;
        }

        /* ── NAVBAR ── */
        .top-navbar {
            height: var(--navbar-height);
            background: var(--primary);
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            display: flex;
            align-items: center;
            padding: 0 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.2);
        }

            .top-navbar .brand {
                color: #fff;
                font-weight: 700;
                font-size: 1.15rem;
                text-decoration: none;
                margin-left: 12px;
                letter-spacing: 0.3px;
            }

                .top-navbar .brand:hover {
                    color: var(--accent);
                    text-decoration: none;
                }

        .toggle-btn {
            background: none;
            border: none;
            color: #fff;
            font-size: 1.2rem;
            cursor: pointer;
            padding: 6px 10px;
            border-radius: 6px;
            transition: background 0.2s;
        }

            .toggle-btn:hover {
                background: rgba(255,255,255,0.12);
            }

        .navbar-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 4px;
        }

            .navbar-right a, .navbar-right button {
                color: rgba(255,255,255,0.85) !important;
                text-decoration: none;
                padding: 6px 12px;
                border-radius: 6px;
                font-size: 0.88rem;
                background: none;
                border: none;
                cursor: pointer;
                transition: all 0.2s;
            }

                .navbar-right a:hover, .navbar-right button:hover {
                    background: rgba(255,255,255,0.12);
                    color: #fff !important;
                }

            .navbar-right .dropdown-menu {
                right: 0;
                left: auto;
                margin-top: 8px;
            }

        .dropdown-menu {
            background: #fff;
            border: 1px solid var(--border);
            box-shadow: 0 8px 24px rgba(0,0,0,0.12);
            border-radius: 10px;
            overflow: hidden;
        }

            .dropdown-menu .dropdown-item {
                color: var(--text-primary) !important;
                padding: 9px 16px;
                font-size: 0.9rem;
                transition: background 0.15s;
            }

                .dropdown-menu .dropdown-item:hover {
                    background: var(--bg);
                }

                .dropdown-menu .dropdown-item.text-danger {
                    color: var(--danger) !important;
                }

                    .dropdown-menu .dropdown-item.text-danger:hover {
                        background: #fff5f5;
                    }

        /* ── SIDEBAR ── */
        .sidebar {
            position: fixed;
            top: var(--navbar-height);
            left: 0;
            width: var(--sidebar-width);
            height: calc(100vh - var(--navbar-height));
            background: var(--primary);
            z-index: 1020;
            overflow-y: auto;
            overflow-x: hidden;
            transition: width 0.25s ease, transform 0.25s ease;
            box-shadow: 3px 0 12px rgba(0,0,0,0.15);
        }

            .sidebar.collapsed {
                width: var(--sidebar-collapsed-width);
            }

            .sidebar .nav-item {
                list-style: none;
            }

            .sidebar .nav-link {
                display: flex;
                align-items: center;
                color: rgba(255,255,255,0.75) !important;
                padding: 11px 16px;
                text-decoration: none;
                white-space: nowrap;
                transition: all 0.2s;
                font-size: 0.88rem;
                border-left: 3px solid transparent;
            }

                .sidebar .nav-link:hover {
                    background: rgba(255,255,255,0.08);
                    color: #fff !important;
                    border-left-color: var(--accent);
                }

                .sidebar .nav-link.active {
                    background: rgba(0,180,216,0.15);
                    color: #fff !important;
                    border-left-color: var(--accent);
                    font-weight: 600;
                }

                .sidebar .nav-link i {
                    width: 28px;
                    font-size: 0.95rem;
                    flex-shrink: 0;
                    text-align: center;
                }

                .sidebar .nav-link .link-text {
                    opacity: 1;
                    transition: opacity 0.2s;
                    margin-left: 6px;
                }

            .sidebar.collapsed .link-text {
                opacity: 0;
                pointer-events: none;
            }

        .sidebar-divider {
            border-top: 1px solid rgba(255,255,255,0.08);
            margin: 6px 12px;
        }

        /* ── MAIN CONTENT ── */
        .main-wrapper {
            margin-left: var(--sidebar-width);
            margin-top: var(--navbar-height);
            padding: 24px;
            transition: margin-left 0.25s ease;
            min-height: calc(100vh - var(--navbar-height));
        }

            .main-wrapper.expanded {
                margin-left: var(--sidebar-collapsed-width);
            }

        /* ── MOBILE OVERLAY ── */
        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 1019;
        }

            .sidebar-overlay.show {
                display: block;
            }

        /* ── CARDS ── */
        .card {
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            border: 1px solid var(--border);
            background: var(--card-bg);
        }

        .card-header {
            background: linear-gradient(135deg, var(--primary) 0%, #1B3A5C 100%);
            color: #fff;
            border-radius: 11px 11px 0 0 !important;
            font-weight: 600;
            font-size: 0.95rem;
            padding: 14px 18px;
            border-bottom: none;
        }

        .card-body {
            padding: 20px;
        }

        /* ── BUTTONS ── */
        .btn {
            border-radius: 8px;
            font-size: 0.88rem;
            font-weight: 500;
            padding: 7px 16px;
            transition: all 0.2s;
        }

        .btn-primary {
            background: var(--primary-hover);
            border-color: var(--primary-hover);
            color: #fff;
        }

            .btn-primary:hover {
                background: #145a94;
                border-color: #145a94;
                color: #fff;
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(27,108,168,0.3);
            }

        .btn-sm {
            padding: 4px 10px;
            font-size: 0.8rem;
            border-radius: 6px;
        }

        .btn-light {
            background: rgba(255,255,255,0.15);
            border-color: rgba(255,255,255,0.3);
            color: #fff;
        }

            .btn-light:hover {
                background: rgba(255,255,255,0.25);
                color: #fff;
                border-color: rgba(255,255,255,0.5);
            }

        .btn-warning {
            border-radius: 6px;
        }

        .btn-danger {
            border-radius: 6px;
        }

        .btn-secondary {
            border-radius: 8px;
            background: #64748B;
            border-color: #64748B;
            color: #fff;
        }

            .btn-secondary:hover {
                background: #4B5563;
                border-color: #4B5563;
                color: #fff;
            }

        /* ── TABLES ── */
        .table {
            font-size: 0.9rem;
        }

            .table thead th {
                background: #F8FAFC;
                color: var(--primary);
                font-weight: 600;
                font-size: 0.82rem;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                border-bottom: 2px solid var(--border);
                padding: 12px 16px;
            }

            .table tbody td {
                padding: 11px 16px;
                vertical-align: middle;
                border-color: var(--border);
            }

        .table-hover tbody tr:hover {
            background: #F8FAFC;
        }

        /* ── FORMS ── */
        .form-control {
            border-radius: 8px;
            border: 1px solid var(--border);
            font-size: 0.9rem;
            padding: 8px 12px;
            transition: border-color 0.2s, box-shadow 0.2s;
            color: var(--text-primary);
        }

            .form-control:focus {
                border-color: var(--primary-hover);
                box-shadow: 0 0 0 3px rgba(27,108,168,0.12);
            }

        label {
            font-weight: 500;
            font-size: 0.88rem;
            color: var(--text-primary);
            margin-bottom: 5px;
        }

        /* ── BADGES ── */
        .badge {
            border-radius: 6px;
            padding: 4px 8px;
            font-size: 0.78rem;
            font-weight: 500;
        }

        .badge-success {
            background: var(--success);
        }

        .badge-danger {
            background: var(--danger);
        }

        .badge-warning {
            background: var(--warning);
            color: #fff;
        }

        .badge-info {
            background: var(--accent);
            color: #fff;
        }

        .badge-secondary {
            background: #94A3B8;
        }

        /* ── ALERTS ── */
        .alert {
            border-radius: 10px;
            border: none;
            font-size: 0.9rem;
        }

        .alert-success {
            background: #ECFDF5;
            color: #065F46;
        }

        .alert-danger {
            background: #FEF2F2;
            color: #991B1B;
        }

        /* ── PAGINATION ── */
        .page-link {
            border-radius: 6px !important;
            margin: 0 2px;
            color: var(--primary-hover);
            border-color: var(--border);
        }

        .page-item.active .page-link {
            background: var(--primary-hover);
            border-color: var(--primary-hover);
        }

        .page-item.disabled .page-link {
            color: var(--text-muted);
        }

        /* ── RTL ── */
        [dir="rtl"] .sidebar {
            left: auto;
            right: 0;
            box-shadow: -3px 0 12px rgba(0,0,0,0.15);
        }

            [dir="rtl"] .sidebar .nav-link {
                border-left: none;
                border-right: 3px solid transparent;
            }

                [dir="rtl"] .sidebar .nav-link:hover,
                [dir="rtl"] .sidebar .nav-link.active {
                    border-right-color: var(--accent);
                    border-left-color: transparent;
                }

        [dir="rtl"] .main-wrapper {
            margin-left: 0;
            margin-right: var(--sidebar-width);
        }

            [dir="rtl"] .main-wrapper.expanded {
                margin-right: var(--sidebar-collapsed-width);
                margin-left: 0;
            }

        [dir="rtl"] .top-navbar .brand {
            margin-left: 0;
            margin-right: 12px;
        }

        [dir="rtl"] .navbar-right {
            margin-left: 0;
            margin-right: auto;
        }

        [dir="rtl"] .sidebar .nav-link .link-text {
            margin-left: 0;
            margin-right: 6px;
        }

        [dir="rtl"] .table {
            direction: rtl;
        }

            [dir="rtl"] .table thead th, [dir="rtl"] .table tbody td {
                text-align: right;
            }

        [dir="rtl"] .card-header {
            text-align: right;
        }

        [dir="rtl"] .form-group label {
            text-align: right;
            display: block;
        }

        /* ── MOBILE ── */
        @@media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
                width: var(--sidebar-width) !important;
            }

            [dir="rtl"] .sidebar {
                transform: translateX(100%);
            }

            .sidebar.mobile-open {
                transform: translateX(0);
            }

            .main-wrapper {
                margin-left: 0 !important;
                margin-right: 0 !important;
                padding: 16px;
            }
        }
    </style>
</head>
<body>

    <!-- TOP NAVBAR -->
    <div class="top-navbar">
        <button class="toggle-btn" id="sidebarToggle">
            <i class="fas fa-bars"></i>
        </button>
        <a class="brand" href="/Home/Index">
            <i class="fas fa-chart-line mr-1"></i>@WebApplication2.Resources.Labels.AppName
        </a>
        <div class="navbar-right">
            <!-- Language -->
            @if (WebApplication2.Helpers.LanguageHelper.IsArabic())
            {
                <a href="/Auth/SetLanguage?lang=en">
                    <i class="fas fa-globe mr-1"></i>English
                </a>
            }
            else
            {
                <a href="/Auth/SetLanguage?lang=ar">
                    <i class="fas fa-globe mr-1"></i>العربية
                </a>
            }
            <!-- User dropdown -->
            <div class="dropdown">
                <button class="dropdown-toggle" data-toggle="dropdown">
                    <i class="fas fa-user mr-1"></i>@User.Identity.Name
                </button>
                <div class="dropdown-menu dropdown-menu-right">
                    <a class="dropdown-item text-danger" href="/Auth/Logout">
                        <i class="fas fa-sign-out-alt mr-2"></i>@WebApplication2.Resources.Labels.Logout
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- SIDEBAR OVERLAY (mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- SIDEBAR -->
    <div class="sidebar" id="sidebar">
        <ul class="nav flex-column pt-2">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Home" ? "active" : "")"
                   href="/Home/Index" title="@WebApplication2.Resources.Labels.Dashboard">
                    <i class="fas fa-home"></i>
                    <span class="link-text">@WebApplication2.Resources.Labels.Dashboard</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Invoices" && ViewContext.RouteData.Values["action"].ToString() == "Create" ? "active" : "")"
                   href="/Invoices/Create" title="@WebApplication2.Resources.Labels.CreateInvoice">
                    <i class="fas fa-file-invoice"></i>
                    <span class="link-text">@WebApplication2.Resources.Labels.CreateInvoice</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Invoices" && ViewContext.RouteData.Values["action"].ToString() != "Create" ? "active" : "")"
                   href="/Invoices/Index" title="@WebApplication2.Resources.Labels.Invoices">
                    <i class="fas fa-list"></i>
                    <span class="link-text">@WebApplication2.Resources.Labels.Invoices</span>
                </a>
            </li>
            <div class="sidebar-divider"></div>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Customers" ? "active" : "")"
                   href="/Customers/Index" title="@WebApplication2.Resources.Labels.Customers">
                    <i class="fas fa-users"></i>
                    <span class="link-text">@WebApplication2.Resources.Labels.Customers</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Products" ? "active" : "")"
                   href="/Products/Index" title="@WebApplication2.Resources.Labels.Products">
                    <i class="fas fa-box"></i>
                    <span class="link-text">@WebApplication2.Resources.Labels.Products</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Categories" ? "active" : "")"
                   href="/Categories/Index" title="@WebApplication2.Resources.Labels.Categories">
                    <i class="fas fa-tags"></i>
                    <span class="link-text">@WebApplication2.Resources.Labels.Categories</span>
                </a>
            </li>
            <div class="sidebar-divider"></div>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Users" ? "active" : "")"
                   href="/Users/Index" title="@WebApplication2.Resources.Labels.Users">
                    <i class="fas fa-user-cog"></i>
                    <span class="link-text">@WebApplication2.Resources.Labels.Users</span>
                </a>
            </li>
        </ul>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-wrapper" id="mainWrapper">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle mr-2"></i>@TempData["Success"]
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle mr-2"></i>@TempData["Error"]
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
            </div>
        }
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.7.3/sweetalert2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>

    <script>
        var isRtl = $('html').attr('dir') === 'rtl';
        var isMobile = window.innerWidth <= 768;

        // Restore sidebar state
        var sidebarCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
        if (!isMobile && sidebarCollapsed) {
            $('#sidebar').addClass('collapsed');
            $('#mainWrapper').addClass('expanded');
        }

        $('#sidebarToggle').on('click', function () {
            if (isMobile) {
                $('#sidebar').toggleClass('mobile-open');
                $('#sidebarOverlay').toggleClass('show');
            } else {
                $('#sidebar').toggleClass('collapsed');
                $('#mainWrapper').toggleClass('expanded');
                localStorage.setItem('sidebarCollapsed', $('#sidebar').hasClass('collapsed'));
            }
        });

        $('#sidebarOverlay').on('click', function () {
            $('#sidebar').removeClass('mobile-open');
            $('#sidebarOverlay').removeClass('show');
        });

        $(window).on('resize', function () {
            isMobile = window.innerWidth <= 768;
            if (!isMobile) {
                $('#sidebar').removeClass('mobile-open');
                $('#sidebarOverlay').removeClass('show');
            }
        });

        // Idle timeout
        var idleTime = 0;
        var warningShown = false;
        var idleInterval = setInterval(timerIncrement, 60000);

        $(document).on('mousemove keydown click scroll', function () {
            if (!warningShown) idleTime = 0;
        });

        function timerIncrement() {
            if (warningShown) return;
            idleTime++;
            if (idleTime >= 2) showIdleWarning();
        }

        function showIdleWarning() {
            warningShown = true;
            Swal.fire({
                title: '@WebApplication2.Resources.Labels.IdleWarning',
                text: '@WebApplication2.Resources.Labels.IdleMessage',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: '@WebApplication2.Resources.Labels.ContinueSession',
                cancelButtonText: '@WebApplication2.Resources.Labels.Logout',
                confirmButtonColor: '#1F3864',
                cancelButtonColor: '#d33',
                allowOutsideClick: false,
                allowEscapeKey: false
            }).then(function (result) {
                if (result.isConfirmed) {
                    $.post('/Auth/KeepAlive');
                    idleTime = 0;
                    warningShown = false;
                } else {
                    window.location.href = '/Auth/Logout';
                }
            });
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>