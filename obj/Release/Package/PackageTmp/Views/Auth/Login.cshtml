@model WebApplication2.Models.ViewModels.LoginViewModel
@using WebApplication2.Resources
@{
    Layout = null;
    var isArabic = WebApplication2.Helpers.LanguageHelper.IsArabic();
    var dir = isArabic ? "rtl" : "ltr";
    var lang = isArabic ? "ar" : "en";
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@WebApplication2.Resources.Labels.Login - @WebApplication2.Resources.Labels.AppName</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.7.3/sweetalert2.min.css" rel="stylesheet" />
    <style>
        body {
            background: #f0f4f8;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .login-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.10);
            padding: 40px 36px;
            width: 100%;
            max-width: 420px;
        }

        .login-title {
            font-size: 1.6rem;
            font-weight: 700;
            color: #1F3864;
            margin-bottom: 6px;
        }

        .login-subtitle {
            color: #6c757d;
            margin-bottom: 28px;
            font-size: 0.95rem;
        }

        .btn-login {
            background: #1F3864;
            color: #fff;
            width: 100%;
            padding: 10px;
            font-size: 1rem;
            border-radius: 8px;
            border: none;
        }

            .btn-login:hover {
                background: #2E5FA3;
                color: #fff;
            }

        .lang-switch {
            text-align: center;
            margin-top: 18px;
            font-size: 0.9rem;
        }

            .lang-switch a {
                color: #2E5FA3;
                text-decoration: none;
            }

                .lang-switch a:hover {
                    text-decoration: underline;
                }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-title">@WebApplication2.Resources.Labels.AppName</div>
        <div class="login-subtitle">@WebApplication2.Resources.Labels.Login</div>

        @using (Html.BeginForm("Login", "Auth", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @Html.ValidationSummary(true)
                </div>
            }

            <div class="form-group">
                <label>@WebApplication2.Resources.Labels.Username</label>
                @Html.TextBoxFor(m => m.Username, new { @class = "form-control", placeholder = WebApplication2.Resources.Labels.Username })
                @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger small" })
            </div>

            <div class="form-group">
                <label>@WebApplication2.Resources.Labels.Password</label>
                @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = WebApplication2.Resources.Labels.Password })
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
            </div>

            <button type="submit" class="btn btn-login">@WebApplication2.Resources.Labels.Login</button>
        }

        <div class="lang-switch">
            @if (isArabic)
            {
                <a href="@Url.Action("SetLanguage", "Auth", new { lang = "en" })">English</a>
            }
            else
            {
                <a href="@Url.Action("SetLanguage", "Auth", new { lang = "ar" })">العربية</a>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.7.3/sweetalert2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    @Scripts.Render("~/bundles/jqueryval")
</body>
</html>