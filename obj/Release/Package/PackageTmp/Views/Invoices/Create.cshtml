@model WebApplication2.Models.ViewModels.InvoiceCreateViewModel
@{
    ViewBag.Title = WebApplication2.Resources.Labels.CreateInvoice;
}

<div class="card">
    <div class="card-header">
        <i class="fas fa-file-invoice mr-2"></i>@WebApplication2.Resources.Labels.CreateInvoice
    </div>
    <div class="card-body">
        @using (Html.BeginForm("Create", "Invoices", FormMethod.Post, new { id = "invoiceForm" }))
        {
            @Html.AntiForgeryToken()

            if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @Html.ValidationSummary(false)
                </div>
            }

            <!-- Customer Selection -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>@WebApplication2.Resources.Labels.InvoiceCustomer <span class="text-danger">*</span></label>
                        <select id="customerSelect" name="CustomerId" class="form-control" style="width:100%">
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>@WebApplication2.Resources.Labels.InvoiceDiscountAmt (%)</label>
                        <input type="number" id="invoiceDiscountPct" name="InvoiceDiscountPct"
                               class="form-control" value="0" min="0" max="100" step="0.01" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>@WebApplication2.Resources.Labels.InvoiceNotes</label>
                        <input type="text" name="Notes" class="form-control" />
                    </div>
                </div>
            </div>

            <!-- Category Filter -->
            <div class="row mb-3">
                <div class="col-md-4">
                    <div class="form-group">
                        <label>Filter by Category</label>
                        <select id="categoryFilter" class="form-control select2-category" style="width:100%">
                            <option value="">All Categories</option>
                            @foreach (var cat in (IEnumerable<WebApplication2.Models.Entities.Category>)ViewBag.Categories)
                            {
                                <option value="@cat.Id">@cat.NameEn</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <!-- Products Table -->
            <div class="table-responsive">
                <table class="table table-bordered" id="itemsTable">
                    <thead>
                        <tr>
                            <th>@WebApplication2.Resources.Labels.InvoiceProducts</th>
                            <th style="width:100px">@WebApplication2.Resources.Labels.InvoiceQty</th>
                            <th style="width:120px">@WebApplication2.Resources.Labels.InvoiceUnitPrice</th>
                            <th style="width:100px">@WebApplication2.Resources.Labels.InvoiceDiscount</th>
                            <th style="width:120px">@WebApplication2.Resources.Labels.InvoiceLineTotal</th>
                            <th style="width:80px"></th>
                        </tr>
                    </thead>
                    <tbody id="itemsBody">
                    </tbody>
                </table>
            </div>

            <button type="button" class="btn btn-secondary mb-3" onclick="addLine()">
                <i class="fas fa-plus mr-1"></i>@WebApplication2.Resources.Labels.AddLine
            </button>

            <!-- Totals -->
            <div class="row justify-content-end">
                <div class="col-md-4">
                    <table class="table table-sm">
                        <tr>
                            <td><strong>@WebApplication2.Resources.Labels.InvoiceSubTotal</strong></td>
                            <td class="text-right" id="subTotalDisplay">0.00</td>
                        </tr>
                        <tr>
                            <td><strong>@WebApplication2.Resources.Labels.InvoiceDiscountAmt</strong></td>
                            <td class="text-right" id="invoiceDiscountDisplay">0.00</td>
                        </tr>
                        <tr class="table-primary">
                            <td><strong>@WebApplication2.Resources.Labels.InvoiceTotal</strong></td>
                            <td class="text-right" id="totalDisplay"><strong>0.00</strong></td>
                        </tr>
                    </table>
                </div>
            </div>

            <div class="d-flex justify-content-between mt-3">
                <a href="/Invoices/Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left mr-1"></i>@WebApplication2.Resources.Labels.Cancel
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save mr-1"></i>@WebApplication2.Resources.Labels.Save
                </button>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
    var rowIndex = 0;
    var allProducts = [];

    // Load all products on page load
    $.get('/Invoices/GetProducts', function (data) {
        allProducts = data;
        addLine(); // add first empty line
    });

    // Category filter change
    $('#categoryFilter').change(function () {
        var categoryId = $(this).val();
        if (categoryId) {
            $.get('/Invoices/GetProducts?categoryId=' + categoryId, function (data) {
                allProducts = data;
                updateAllProductDropdowns();
            });
        } else {
            $.get('/Invoices/GetProducts', function (data) {
                allProducts = data;
                updateAllProductDropdowns();
            });
        }
    });

    function updateAllProductDropdowns() {
    $('#itemsBody tr').each(function () {
        var select = $(this).find('.product-select');
        var currentVal = select.val();

        // If row already has a product selected, don't touch it
        if (currentVal) return;

        // Only update empty rows
        select.empty().append('<option value="">@WebApplication2.Resources.Labels.SelectProduct</option>');
        $.each(allProducts, function (i, p) {
            select.append('<option value="' + p.id + '" data-price="' + p.price + '">' + p.text + '</option>');
        });
        select.trigger('change.select2');
    });
}

    function addLine() {
        var options = '<option value="">@WebApplication2.Resources.Labels.SelectProduct</option>';
        $.each(allProducts, function (i, p) {
            options += '<option value="' + p.id + '" data-price="' + p.price + '">' + p.text + '</option>';
        });

        var row = '<tr id="line-' + rowIndex + '">' +
            '<td>' +
                '<select name="Items[' + rowIndex + '].ProductId" class="form-control product-select" style="width:100%">' +
                    options +
                '</select>' +
                '<input type="hidden" name="Items[' + rowIndex + '].UnitPrice" class="unit-price-input" value="0" />' +
            '</td>' +
            '<td>' +
                '<input type="number" name="Items[' + rowIndex + '].Quantity" class="form-control qty-input" value="1" min="1" />' +
            '</td>' +
            '<td>' +
                '<input type="text" class="form-control unit-price-display" readonly value="0.00" />' +
            '</td>' +
            '<td>' +
                '<input type="number" name="Items[' + rowIndex + '].DiscountPct" class="form-control discount-input" value="0" min="0" max="100" step="0.01" />' +
            '</td>' +
            '<td>' +
                '<input type="text" class="form-control line-total" readonly value="0.00" />' +
            '</td>' +
            '<td>' +
                '<button type="button" class="btn btn-sm btn-danger" onclick="removeLine(' + rowIndex + ')">'+
                    '<i class="fas fa-times"></i>' +
                '</button>' +
            '</td>' +
        '</tr>';

        $('#itemsBody').append(row);

        // Initialize Select2 on the new row
        $('#line-' + rowIndex + ' .product-select').select2({
            placeholder: '@WebApplication2.Resources.Labels.SelectProduct'
        }).on('change', function () {
            var selected = $(this).find(':selected');
            var price = parseFloat(selected.data('price')) || 0;
            var row = $(this).closest('tr');
            row.find('.unit-price-input').val(price);
            row.find('.unit-price-display').val(price.toFixed(2));
            calculateRow(row);
        });

        // Recalculate on qty/discount change
        $('#line-' + rowIndex + ' .qty-input, #line-' + rowIndex + ' .discount-input').on('input', function () {
            calculateRow($(this).closest('tr'));
        });

        rowIndex++;
    }

    function removeLine(index) {
        if ($('#itemsBody tr').length === 1) {
            Swal.fire({
                title: 'Cannot remove',
                text: '@WebApplication2.Resources.Labels.InvoiceNoItems',
                icon: 'warning'
            });
            return;
        }
        $('#line-' + index).remove();
        calculateTotals();
    }

    function calculateRow(row) {
        var price = parseFloat(row.find('.unit-price-input').val()) || 0;
        var qty = parseInt(row.find('.qty-input').val()) || 0;
        var discount = parseFloat(row.find('.discount-input').val()) || 0;
        var discountAmt = price * qty * discount / 100;
        var lineTotal = (price * qty) - discountAmt;
        row.find('.line-total').val(lineTotal.toFixed(2));
        calculateTotals();
    }

    function calculateTotals() {
        var subTotal = 0;
        $('.line-total').each(function () {
            subTotal += parseFloat($(this).val()) || 0;
        });

        var invoiceDiscount = parseFloat($('#invoiceDiscountPct').val()) || 0;
        var invoiceDiscountAmt = subTotal * invoiceDiscount / 100;
        var total = subTotal - invoiceDiscountAmt;

        $('#subTotalDisplay').text(subTotal.toFixed(2));
        $('#invoiceDiscountDisplay').text(invoiceDiscountAmt.toFixed(2));
        $('#totalDisplay').html('<strong>' + total.toFixed(2) + '</strong>');
    }

    $('#invoiceDiscountPct').on('input', calculateTotals);

    // Customer Select2 with AJAX
    $('#customerSelect').select2({
        placeholder: '@WebApplication2.Resources.Labels.SelectCustomer',
        minimumInputLength: 1,
        ajax: {
            url: '/Customers/Search',
            dataType: 'json',
            delay: 250,
            data: function (params) { return { term: params.term }; },
            processResults: function (data) {
                return { results: data };
            }
        }
    });

    // Category Select2
    $('.select2-category').select2({
        placeholder: 'All Categories',
        allowClear: true
    });
    </script>
}