@model IEnumerable<WebApplication2.Models.ViewModels.ProductViewModel>
@{
    ViewBag.Title = WebApplication2.Resources.Labels.Products;
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-box mr-2"></i>@WebApplication2.Resources.Labels.Products</span>
        <a href="/Products/Create" class="btn btn-sm btn-light">
            <i class="fas fa-plus mr-1"></i>@WebApplication2.Resources.Labels.AddProduct
        </a>
    </div>
    <div class="card-body">
        <!-- Category Filter -->
        <div class="row mb-3">
            <div class="col-md-4">
                @using (Html.BeginForm("Index", "Products", FormMethod.Get))
                {
                    <div class="input-group">
                        @Html.DropDownList("categoryId",
                            new SelectList(ViewBag.Categories, "Value", "Text", ViewBag.CategoryId),
                            WebApplication2.Resources.Labels.SelectCategory,
                            new { @class = "form-control select2" })
                        <div class="input-group-append">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-filter"></i>
                            </button>
                            <a href="/Products/Index" class="btn btn-secondary">
                                <i class="fas fa-times"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>@WebApplication2.Resources.Labels.ProductNameEn</th>
                        <th>@WebApplication2.Resources.Labels.ProductNameAr</th>
                        <th>@WebApplication2.Resources.Labels.ProductCategory</th>
                        <th>@WebApplication2.Resources.Labels.ProductPrice</th>
                        <th>@WebApplication2.Resources.Labels.ProductStock</th>
                        <th>@WebApplication2.Resources.Labels.Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">
                                @WebApplication2.Resources.Labels.NoData
                            </td>
                        </tr>
                    }
                    else
                    {
                        int i = 1;
                        foreach (var item in Model)
                        {
                            <tr id="row-@item.Id">
                                <td>@i</td>
                                <td>@item.NameEn</td>
                                <td>@item.NameAr</td>
                                <td>@item.CategoryName</td>
                                <td>@item.Price.ToString("N2")</td>
                                <td>@item.StockQuantity</td>
                                <td>
                                    <a href="/Products/Edit/@item.Id" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button class="btn btn-sm btn-danger"
                                            onclick="confirmDelete(@item.Id, '@item.NameEn')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.select2').select2({
                placeholder: '@WebApplication2.Resources.Labels.SelectCategory',
                allowClear: true
            });
        });

        function confirmDelete(id, name) {
            Swal.fire({
                title: '@WebApplication2.Resources.Labels.ConfirmDelete',
                text: name,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#1F3864',
                confirmButtonText: '@WebApplication2.Resources.Labels.Yes',
                cancelButtonText: '@WebApplication2.Resources.Labels.Cancel'
            }).then(function (result) {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Products/Delete/' + id,
                        type: 'POST',
                        data: {
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (response) {
                            if (response.success) {
                                $('#row-' + id).fadeOut(400, function () { $(this).remove(); });
                                Swal.fire({
                                    title: response.message,
                                    icon: 'success',
                                    timer: 1500,
                                    showConfirmButton: false
                                });
                            } else {
                                Swal.fire({
                                    title: response.message,
                                    icon: 'error'
                                });
                            }
                        }
                    });
                }
            });
        }
    </script>
}