@model WebApplication2.Models.ViewModels.UserViewModel
@{
    ViewBag.Title = WebApplication2.Resources.Labels.EditUser;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-edit mr-2"></i>@WebApplication2.Resources.Labels.EditUser
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Edit", "Users", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.Id)

                    if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @Html.ValidationSummary(false)
                        </div>
                    }

                    <div class="form-group">
                        <label>@WebApplication2.Resources.Labels.UserUsername <span class="text-danger">*</span></label>
                        @Html.TextBoxFor(m => m.Username, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger small" })
                    </div>

                    <div class="form-group">
                        <label>@WebApplication2.Resources.Labels.UserFullName <span class="text-danger">*</span></label>
                        @Html.TextBoxFor(m => m.FullName, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger small" })
                    </div>

                    <div class="form-group">
                        <label>@WebApplication2.Resources.Labels.UserEmail</label>
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a href="/Users/Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left mr-1"></i>@WebApplication2.Resources.Labels.Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save mr-1"></i>@WebApplication2.Resources.Labels.Save
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>